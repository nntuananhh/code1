<Window x:Class="WpfApp3.Dialogs.EditTransactionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Chỉnh sửa giao dịch" Height="609" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Chỉnh sửa giao dịch" FontSize="24" FontWeight="Bold" 
                     Foreground="{DynamicResource MaterialDesignBody}"/>
            <TextBlock Text="Cập nhật thông tin giao dịch" FontSize="14" 
                     Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <!-- Transaction Type -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Loại giao dịch" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <ComboBox x:Name="TransactionTypeComboBox" 
                         materialDesign:HintAssist.Hint="Chọn loại giao dịch"
                         Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                    <ComboBoxItem Content="Thu nhập" Tag="Income"/>
                    <ComboBoxItem Content="Chi tiêu" Tag="Expense"/>
                </ComboBox>
            </StackPanel>

            <!-- Amount -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Số tiền" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="AmountTextBox" 
                        materialDesign:HintAssist.Hint="Nhập số tiền"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        PreviewTextInput="AmountTextBox_PreviewTextInput"/>
            </StackPanel>

            <!-- Description -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Mô tả" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="DescriptionTextBox" 
                        materialDesign:HintAssist.Hint="Nhập mô tả giao dịch"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>
            </StackPanel>

            <!-- Category -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Danh mục" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <ComboBox x:Name="CategoryComboBox" 
                         materialDesign:HintAssist.Hint="Chọn danh mục"
                         Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>
            </StackPanel>

            <!-- Date -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Ngày giao dịch" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <DatePicker x:Name="DatePicker" 
                           materialDesign:HintAssist.Hint="Chọn ngày"
                           Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                           DisplayDateEnd="{x:Static sys:DateTime.Today}"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="CancelButton" Content="Hủy" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Lưu" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    Foreground="Black" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
