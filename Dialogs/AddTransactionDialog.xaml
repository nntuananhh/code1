<Window x:Class="WpfApp3.Dialogs.AddTransactionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Thêm giao dịch mới" Height="637" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="DialogTitle" Text="Thêm giao dịch mới" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="{DynamicResource MaterialDesignBody}"/>
            <TextBlock x:Name="DialogSubtitle" Text="Nhập thông tin giao dịch" 
                       FontSize="14" 
                       Foreground="{DynamicResource MaterialDesignBodyLight}" 
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <!-- Transaction Type -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Loại giao dịch" FontSize="14" FontWeight="Medium" 
                           Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <ComboBox x:Name="TransactionTypeComboBox" 
                          materialDesign:HintAssist.Hint="Chọn loại giao dịch"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                    <ComboBoxItem Content="Thu nhập" Tag="Income"/>
                    <ComboBoxItem Content="Chi tiêu" Tag="Expense"/>
                </ComboBox>
            </StackPanel>

            <!-- Amount -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Số tiền" FontSize="14" FontWeight="Medium" 
                           Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="AmountTextBox" 
                         materialDesign:HintAssist.Hint="Nhập số tiền"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         PreviewTextInput="AmountTextBox_PreviewTextInput"/>
            </StackPanel>

            <!-- Description -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Mô tả" FontSize="14" FontWeight="Medium" 
                           Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="DescriptionTextBox" 
                         materialDesign:HintAssist.Hint="Nhập mô tả giao dịch"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>
            </StackPanel>

            <!-- Category -->
            <StackPanel Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Danh mục" FontSize="14" FontWeight="Medium" 
                              Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                    
                    <Button Grid.Column="1" x:Name="AddCategoryButton" 
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                            Click="AddCategoryButton_Click"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" 
                                                   Margin="0,0,4,0"/>
                            <TextBlock Text="Thêm danh mục" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Grid>
                
                <ComboBox x:Name="CategoryComboBox" 
                         materialDesign:HintAssist.Hint="Chọn danh mục"
                         Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>
            </StackPanel>

            <!-- Date -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Ngày giao dịch" FontSize="14" FontWeight="Medium" 
                           Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <DatePicker x:Name="DatePicker" 
                            materialDesign:HintAssist.Hint="Chọn ngày"
                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                            DisplayDateEnd="{x:Static sys:DateTime.Today}"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="CancelButton" Content="Hủy" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    Click="CancelButton_Click" Margin="0,0,8,0"/>
            <Button x:Name="SaveButton" Content="Lưu" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    Foreground="Black"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
