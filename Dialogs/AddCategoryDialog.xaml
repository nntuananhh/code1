<Window x:Class="WpfApp3.Dialogs.AddCategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Thêm danh mục" Height="558" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Thêm danh mục mới" FontSize="24" FontWeight="Bold" 
                     Foreground="{DynamicResource MaterialDesignBody}"/>
            <TextBlock Text="Tạo danh mục mới cho giao dịch" FontSize="14" 
                     Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <!-- Category Type -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Loại danh mục" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <ComboBox x:Name="CategoryTypeComboBox" 
                         materialDesign:HintAssist.Hint="Chọn loại danh mục"
                         Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                    <ComboBoxItem Content="Thu nhập" Tag="Income"/>
                    <ComboBoxItem Content="Chi tiêu" Tag="Expense"/>
                </ComboBox>
            </StackPanel>

            <!-- Category Name -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Tên danh mục" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="CategoryNameTextBox" 
                        materialDesign:HintAssist.Hint="Nhập tên danh mục"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
            </StackPanel>

            <!-- Color -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Màu sắc" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                
                <!-- Color Input -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="ColorTextBox" Grid.Column="0" 
                            materialDesign:HintAssist.Hint="Mã màu (VD: #FF5722)"
                            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                            Text="#2196F3"/>
                    
                    <Border Grid.Column="1" x:Name="ColorPreview" 
                           Background="#2196F3" Width="40" Height="40" 
                           CornerRadius="20" Margin="8,0,0,0"
                           BorderBrush="{DynamicResource MaterialDesignDivider}"
                           BorderThickness="1"/>
                </Grid>
                
                <!-- Quick Color Selection -->
                <TextBlock Text="Màu nhanh:" FontSize="12" 
                          Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,4"/>
                <WrapPanel>
                    <Button x:Name="ColorBlue" Background="#2196F3" Width="30" Height="30" 
                           Margin="0,0,4,4" Click="QuickColor_Click" Tag="#2196F3"
                           Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button x:Name="ColorGreen" Background="#4CAF50" Width="30" Height="30" 
                           Margin="0,0,4,4" Click="QuickColor_Click" Tag="#4CAF50"
                           Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button x:Name="ColorOrange" Background="#FF9800" Width="30" Height="30" 
                           Margin="0,0,4,4" Click="QuickColor_Click" Tag="#FF9800"
                           Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button x:Name="ColorRed" Background="#F44336" Width="30" Height="30" 
                           Margin="0,0,4,4" Click="QuickColor_Click" Tag="#F44336"
                           Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button x:Name="ColorPurple" Background="#9C27B0" Width="30" Height="30" 
                           Margin="0,0,4,4" Click="QuickColor_Click" Tag="#9C27B0"
                           Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button x:Name="ColorTeal" Background="#00BCD4" Width="30" Height="30" 
                           Margin="0,0,4,4" Click="QuickColor_Click" Tag="#00BCD4"
                           Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button x:Name="ColorLime" Background="#8BC34A" Width="30" Height="30" 
                           Margin="0,0,4,4" Click="QuickColor_Click" Tag="#8BC34A"
                           Style="{StaticResource MaterialDesignFlatButton}"/>
                    <Button x:Name="ColorPink" Background="#E91E63" Width="30" Height="30" 
                           Margin="0,0,4,4" Click="QuickColor_Click" Tag="#E91E63"
                           Style="{StaticResource MaterialDesignFlatButton}"/>
                </WrapPanel>
            </StackPanel>

            <!-- Icon -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Biểu tượng" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <ComboBox x:Name="IconComboBox" 
                         materialDesign:HintAssist.Hint="Chọn biểu tượng"
                         Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                    <ComboBoxItem Content="💰 Tiền" Tag="CurrencyUsd"/>
                    <ComboBoxItem Content="🛒 Mua sắm" Tag="Shopping"/>
                    <ComboBoxItem Content="🍽️ Ăn uống" Tag="Restaurant"/>
                    <ComboBoxItem Content="⛽ Xăng" Tag="GasStation"/>
                    <ComboBoxItem Content="🏠 Nhà ở" Tag="Home"/>
                    <ComboBoxItem Content="🚗 Giao thông" Tag="Car"/>
                    <ComboBoxItem Content="💊 Y tế" Tag="MedicalBag"/>
                    <ComboBoxItem Content="🎓 Giáo dục" Tag="School"/>
                    <ComboBoxItem Content="🎮 Giải trí" Tag="GamepadVariant"/>
                    <ComboBoxItem Content="👕 Quần áo" Tag="TshirtCrew"/>
                    <ComboBoxItem Content="💼 Công việc" Tag="Briefcase"/>
                    <ComboBoxItem Content="🎁 Quà tặng" Tag="Gift"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="CancelButton" Content="Hủy" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Lưu" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    Foreground="Black" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
