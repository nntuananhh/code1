<Window x:Class="WpfApp3.Dialogs.AddMoneyToGoalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Thêm tiền vào mục tiêu" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Thêm tiền vào mục tiêu" FontSize="24" FontWeight="Bold" 
                     Foreground="{DynamicResource MaterialDesignBody}"/>
            <TextBlock x:Name="GoalNameText" Text="Mục tiêu: Tên mục tiêu" FontSize="14" 
                     Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <!-- Current Progress -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Tiến độ hiện tại" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <StackPanel>
                    <ProgressBar x:Name="CurrentProgressBar" Value="0" Maximum="100" Height="12" 
                                Background="#E0E0E0" Foreground="#4CAF50"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="CurrentAmountText" Text="₫0" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock Text=" / " FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock x:Name="TargetAmountText" Text="₫0" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock Text=" (" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock x:Name="ProgressPercentageText" Text="0%" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock Text=")" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Amount to Add -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Số tiền thêm vào" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="AmountToAddTextBox" 
                        materialDesign:HintAssist.Hint="Nhập số tiền muốn thêm vào mục tiêu"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        PreviewTextInput="AmountTextBox_PreviewTextInput"
                        TextChanged="AmountToAddTextBox_TextChanged"/>
            </StackPanel>

            <!-- New Progress Preview -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Tiến độ sau khi thêm" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <StackPanel>
                    <ProgressBar x:Name="NewProgressBar" Value="0" Maximum="100" Height="12" 
                                Background="#E0E0E0" Foreground="#2196F3"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="NewAmountText" Text="₫0" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock Text=" / " FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock x:Name="NewTargetAmountText" Text="₫0" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock Text=" (" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock x:Name="NewProgressPercentageText" Text="0%" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <TextBlock Text=")" FontSize="12" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Completion Check -->
            <Border x:Name="CompletionCheckBorder" Background="#E8F5E8" CornerRadius="8" 
                   Padding="12" Margin="0,0,0,16" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CheckCircle" Width="20" Height="20" 
                                           Foreground="#4CAF50" Margin="0,0,8,0"/>
                    <TextBlock x:Name="CompletionText" Text="Mục tiêu sẽ được hoàn thành!" 
                             FontSize="14" FontWeight="Medium" Foreground="#4CAF50"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="CancelButton" Content="Hủy" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="AddButton" Content="Thêm tiền" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#4CAF50"
                    Foreground="White" Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>































