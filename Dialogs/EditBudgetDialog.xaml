<Window x:Class="WpfApp3.Dialogs.EditBudgetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Chỉnh sửa ngân sách" Height="672" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Chỉnh sửa ngân sách" FontSize="24" FontWeight="Bold" 
                     Foreground="{DynamicResource MaterialDesignBody}"/>
            <TextBlock Text="Cập nhật thông tin ngân sách" FontSize="14" 
                     Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <!-- Category (Read-only) -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Danh mục" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="CategoryTextBox" 
                        materialDesign:HintAssist.Hint="Danh mục"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        IsReadOnly="True"/>
            </StackPanel>

            <!-- Budget Amount -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Số tiền ngân sách" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="AmountTextBox" 
                        materialDesign:HintAssist.Hint="Nhập số tiền ngân sách"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        PreviewTextInput="AmountTextBox_PreviewTextInput"/>
            </StackPanel>

            <!-- Spent Amount (Read-only) -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Đã chi tiêu" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="SpentAmountTextBox" 
                        materialDesign:HintAssist.Hint="Số tiền đã chi"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        IsReadOnly="True"/>
            </StackPanel>

            <!-- Start Date -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Ngày bắt đầu" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <DatePicker x:Name="StartDatePicker" 
                           materialDesign:HintAssist.Hint="Chọn ngày bắt đầu"
                           Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
            </StackPanel>

            <!-- End Date -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Ngày kết thúc" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <DatePicker x:Name="EndDatePicker" 
                           materialDesign:HintAssist.Hint="Chọn ngày kết thúc"
                           Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
            </StackPanel>

            <!-- Active Status -->
            <StackPanel Margin="0,0,0,16">
                <CheckBox x:Name="IsActiveCheckBox" Content="Ngân sách đang hoạt động" 
                         FontSize="14" FontWeight="Medium" 
                         Foreground="{DynamicResource MaterialDesignBody}"/>
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="CancelButton" Content="Hủy" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Lưu" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    Foreground="Black" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

















