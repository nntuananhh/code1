<Window x:Class="WpfApp3.Dialogs.AddBudgetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Thêm hũ chi tiêu" Height="570" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Thêm hũ chi tiêu mới" FontSize="24" FontWeight="Bold" 
                     Foreground="{DynamicResource MaterialDesignBody}"/>
            <TextBlock Text="Tạo hũ chi tiêu cho danh mục chi tiêu" FontSize="14" 
                     Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Form -->
        <StackPanel Grid.Row="1">
            <!-- Category -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Danh mục" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <ComboBox x:Name="CategoryComboBox" 
                         materialDesign:HintAssist.Hint="Chọn danh mục chi tiêu"
                         Style="{DynamicResource MaterialDesignFloatingHintComboBox}"/>
            </StackPanel>

            <!-- Budget Amount -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Số tiền hũ chi tiêu" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <TextBox x:Name="AmountTextBox" 
                        materialDesign:HintAssist.Hint="Nhập số tiền hũ chi tiêu"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        PreviewTextInput="AmountTextBox_PreviewTextInput"/>
            </StackPanel>

            <!-- Period -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Kỳ hũ chi tiêu" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <ComboBox x:Name="PeriodComboBox" 
                         materialDesign:HintAssist.Hint="Chọn kỳ hũ chi tiêu"
                         Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                    <ComboBoxItem Content="Hàng tháng" Tag="Monthly"/>
                    <ComboBoxItem Content="Hàng quý" Tag="Quarterly"/>
                    <ComboBoxItem Content="Hàng năm" Tag="Yearly"/>
                </ComboBox>
            </StackPanel>

            <!-- Start Date -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Ngày bắt đầu" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <DatePicker x:Name="StartDatePicker" 
                           materialDesign:HintAssist.Hint="Chọn ngày bắt đầu"
                           Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
            </StackPanel>

            <!-- End Date -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Ngày kết thúc" FontSize="14" FontWeight="Medium" 
                          Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                <DatePicker x:Name="EndDatePicker" 
                           materialDesign:HintAssist.Hint="Chọn ngày kết thúc"
                           Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
            </StackPanel>

        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button x:Name="CancelButton" Content="Hủy" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Lưu" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{DynamicResource PrimaryHueMidBrush}"
                    Foreground="Black" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
