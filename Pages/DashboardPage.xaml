<Page x:Class="WpfApp3.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Dashboard" Height="567">

    <Grid Background="#FAFAFA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32" Grid.ColumnSpan="2">
            <StackPanel>
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Balance Card -->
                    <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="24" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="4" Color="#E0E0E0"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#2196F3" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="AccountBalance" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Tổng số dư" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="TotalBalanceText" Text="₫0" FontSize="24" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Monthly Income Card -->
                    <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="24" Margin="6,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#4CAF50" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="TrendingUp" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Thu nhập tháng" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="MonthlyIncomeText" Text="₫0" FontSize="24" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Monthly Expense Card -->
                    <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="24" Margin="6,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="4" Color="#E0E0E0"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#F44336" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="TrendingDown" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Chi tiêu tháng" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="MonthlyExpenseText" Text="₫0" FontSize="24" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Savings Rate Card -->
                    <Border Grid.Column="3" Background="White" CornerRadius="16" Padding="24" Margin="12,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="4" Color="#E0E0E0"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#FF9800" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="PiggyBank" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Tỷ lệ tiết kiệm" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="SavingsRateText" Text="0%" FontSize="24" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Charts and Recent Transactions -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Expense Chart -->
                    <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="24" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="4" Color="#E0E0E0"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Chi tiêu theo danh mục" FontSize="20" FontWeight="Bold" 
                                     Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,24"/>

                            <!-- Chart -->
                            <lvc:PieChart x:Name="ExpenseChart" 
                                         Series="{Binding ExpenseSeries}"
                                         Height="300"
                                         LegendPosition="Bottom"
                                         TooltipPosition="Right">
                            </lvc:PieChart>
                        </StackPanel>
                    </Border>

                    <!-- Recent Transactions -->
                    <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="24" Margin="12,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="4" Color="#E0E0E0"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Giao dịch gần đây" FontSize="20" FontWeight="Bold" Margin="0 0 0 16" 
                                         Foreground="{DynamicResource MaterialDesignBodyhi}"/>

                            <!-- Transaction List -->
                            <StackPanel x:Name="TransactionList">
                                <!-- Transactions will be added dynamically -->
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>