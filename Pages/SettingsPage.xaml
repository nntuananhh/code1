<Page x:Class="WpfApp3.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Cài đặt">

    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,0,32,32">
            <StackPanel>

                <Border Background="White" CornerRadius="16" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="AccountEdit" Width="24" Height="24" 
                                                   Foreground="#9C27B0" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Thông tin cá nhân" FontSize="20" FontWeight="Bold" 
                                       Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Cập nhật thông tin cá nhân và ảnh đại diện" 
                                   FontSize="14" Foreground="{DynamicResource MaterialDesignBodyLight}" 
                                   Margin="0,0,0,20"/>

                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                            <Border x:Name="AvatarBorder" CornerRadius="40" Width="80" Height="80" 
                                    Background="{DynamicResource MaterialDesignDivider}" 
                                    BorderBrush="{DynamicResource MaterialDesignDivider}" 
                                    BorderThickness="2" HorizontalAlignment="Center">
                                <Grid>
                                    <Image x:Name="AvatarImage" Stretch="UniformToFill"/>
                                    <materialDesign:PackIcon x:Name="DefaultAvatarIcon" Kind="AccountCircle" Width="60" Height="60" 
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                </Grid>
                            </Border>

                            <Button x:Name="UploadAvatarButton" Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{DynamicResource PrimaryHueMidBrush}" 
                                    Foreground="Black" Margin="0,12,0,0" Padding="16,8"
                                    Click="UploadAvatarButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Camera" Width="16" Height="16" 
                                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Tải ảnh đại diện lên" FontSize="14" FontWeight="Medium"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="Họ và tên" FontSize="14" FontWeight="Medium" 
                                           Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,6"/>
                                <TextBox x:Name="FullNameTextBox" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Nhập họ và tên"
                                         FontSize="14"
                                         
                                         AutomationProperties.Name="Họ và tên"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="Email" FontSize="14" FontWeight="Medium" 
                                           Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,6"/>
                                <TextBox x:Name="EmailTextBox" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Nhập địa chỉ email"
                                         FontSize="14"
                                         
                                         AutomationProperties.Name="Email"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,16">
                                <TextBlock Text="Tên đăng nhập" FontSize="14" FontWeight="Medium" 
                                           Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,6"/>
                                <TextBox x:Name="UsernameTextBox" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Tên đăng nhập (không thể thay đổi)"
                                         FontSize="14" IsReadOnly="True" 
                                         Background="{DynamicResource MaterialDesignDivider}"
                                         
                                         AutomationProperties.Name="Tên đăng nhập"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,16">
                                <TextBlock Text="Ngày tạo tài khoản" FontSize="14" FontWeight="Medium" 
                                           Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,6"/>
                                <TextBox x:Name="CreatedDateTextBox" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Ngày tạo tài khoản"
                                         FontSize="14" IsReadOnly="True" 
                                         Background="{DynamicResource MaterialDesignDivider}"
                                         
                                         AutomationProperties.Name="Ngày tạo tài khoản"/>
                            </StackPanel>

                            <Button x:Name="SaveProfileButton" Grid.Row="2" Grid.ColumnSpan="2"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{DynamicResource PrimaryHueMidBrush}" 
                                    Foreground="Black" Content="Lưu thay đổi" FontSize="14" 
                                    Click="SaveProfileButton_Click" 
                                    HorizontalAlignment="Left" Margin="0,8,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="16" Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Database" Width="24" Height="24" 
                                                   Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Quản lý dữ liệu" FontSize="20" FontWeight="Bold" 
                                       Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Quản lý và bảo trì dữ liệu ứng dụng" 
                                   FontSize="14" Foreground="{DynamicResource MaterialDesignBodyLight}" 
                                   Margin="0,0,0,20"/>

                        <Button x:Name="ResetDataButton" Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#F44336" Foreground="White"
                                Click="ResetDataButton_Click" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" 
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Reset Data" FontSize="15" FontWeight="Medium"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="⚠️ Cảnh báo: Hành động này sẽ xóa TẤT CẢ dữ liệu và không thể hoàn tác!" 
                                   FontSize="12" Foreground="#F44336" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>