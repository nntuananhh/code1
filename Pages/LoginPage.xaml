<Page x:Class="WpfApp3.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Đăng nhập" Height="594">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,40">
            <materialDesign:PackIcon Kind="AccountCircle" 
                                   Width="80" Height="80" 
                                   Foreground="#2196F3"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <TextBlock Text="Quản lý tài chính cá nhân" 
                      FontSize="24" FontWeight="Bold"
                      Foreground="#333333"
                      HorizontalAlignment="Center" Margin="0,0,0,10"/>
            
            <TextBlock Text="Đăng nhập để tiếp tục" 
                      FontSize="16" 
                      Foreground="#666666"
                      HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Login Form -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="12" 
                Padding="40" 
                MaxWidth="400" 
                HorizontalAlignment="Center"
                Margin="20 0 20 40"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <StackPanel>
                <TextBox x:Name="UsernameTextBox"
                        materialDesign:HintAssist.Hint="Tên đăng nhập"
                        materialDesign:HintAssist.IsFloating="True"
                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                        Margin="0,0,0,20"
                        FontSize="16"
                        KeyDown="TextBox_KeyDown"/>
                <PasswordBox x:Name="PasswordBox"
                            materialDesign:HintAssist.Hint="Mật khẩu"
                            materialDesign:HintAssist.IsFloating="True"
                            Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                            Margin="0,0,0,20"
                            FontSize="16"
                            KeyDown="PasswordBox_KeyDown"/>
                <Button x:Name="LoginButton"
                       Content="ĐĂNG NHẬP"
                       Style="{StaticResource MaterialDesignRaisedButton}"
                       Background="#2196F3"
                       Foreground="White"
                       FontSize="16" FontWeight="Bold"
                       Height="45"
                       Margin="0,0,0,16"
                       Click="LoginButton_Click"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Chưa có tài khoản? " VerticalAlignment="Center"
                              Foreground="#666666"
                              FontSize="14" />
                    <Button x:Name="RegisterLinkButton"
                           Content="Đăng ký ngay"
                           Style="{StaticResource MaterialDesignFlatButton}"
                           Foreground="#2196F3"
                           FontWeight="Bold"
                           FontSize="14"
                           Click="RegisterLinkButton_Click"/>
                </StackPanel>
                <!-- Error Message -->
                <TextBlock x:Name="ErrorMessageTextBlock"
                          Foreground="#F44336"
                          FontSize="14"
                          TextWrapping="Wrap"
                          HorizontalAlignment="Center"
                          Margin="0,10,0,0"
                          Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>













