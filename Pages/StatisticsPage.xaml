<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="WpfApp3.Pages.StatisticsPage"
      Title="Thống kê">


    <Grid Background="#FAFAFA">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
            <StackPanel>

                <!-- Filter Period -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Chọn khoảng thời gian:" 
                             FontSize="16" FontWeight="Medium" 
                             Margin="40 0 0 0"
                             VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="ThisMonthButton" Content="6 tháng" 
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Click="PeriodButton_Click" Tag="Last6Months" Margin="0,0,8,0"/>
                        <Button x:Name="ThisYearButton" Content="Năm nay" 
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Click="PeriodButton_Click" Tag="ThisYear"/>
                    </StackPanel>
                </Grid>

                <!-- Current Period Display -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="Calendar" Width="24" Height="24" 
                                                    Foreground="{DynamicResource PrimaryHueMidBrush}" 
                                                    VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock x:Name="CurrentPeriodText" Text="Tháng này - Tháng 10/2025" 
                                     FontSize="18" FontWeight="Bold" 
                                     Foreground="{DynamicResource MaterialDesignBody}"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="PeriodDescriptionText" Text="Dữ liệu hiển thị cho khoảng thời gian được chọn" 
                                 FontSize="14" 
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"
                                 HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Summary Cards -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Income -->
                    <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="24" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#4CAF50" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="TrendingUp" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Tổng thu nhập" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="TotalIncomeText" Text="₫0" FontSize="20" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Total Expense -->
                    <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="24" Margin="6,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#F44336" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="TrendingDown" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Tổng chi tiêu" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="TotalExpenseText" Text="₫0" FontSize="20" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Savings Rate -->
                    <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="24" Margin="12,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#FF9800" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="PiggyBank" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Tỷ lệ tiết kiệm" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="SavingsRateText" Text="0%" FontSize="20" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Charts Row -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <!-- Category Spending Chart -->
                    <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="24" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Chi tiêu theo danh mục" FontSize="18" FontWeight="Bold" 
                                     Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,24"/>

                            <lvc:PieChart x:Name="CategoryChart" Height="300" 
                                        Series="{Binding CategorySeries}"
                                        LegendPosition="Bottom"
                                        TooltipPosition="Right">
                            </lvc:PieChart>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Monthly Trend Chart -->
                <Border Background="White" CornerRadius="16" Padding="24" Margin="0,0,0,32">
                    <StackPanel>
                        <StackPanel>
                            <TextBlock Text="Xu hướng hàng tháng" FontSize="18" FontWeight="Bold" 
                                     Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,8"/>
                            <TextBlock Text="💡 Di chuột vào đường để xem chi tiết tháng" FontSize="12" 
                                     Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,16"/>
                        </StackPanel>

                        <lvc:CartesianChart x:Name="MonthlyTrendChart" Height="300" 
                                          Series="{Binding MonthlyTrendSeries}"
                                          XAxes="{Binding XAxes}"
                                          YAxes="{Binding YAxes}"
                                          TooltipPosition="Right">
                        </lvc:CartesianChart>

                        <!-- Legend for Monthly Trend Chart -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                <Rectangle Width="16" Height="3" Fill="#81C784" Margin="0,0,8,0"/>
                                <TextBlock Text="Thu nhập" FontSize="14" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="16" Height="3" Fill="#EF9A9A" Margin="0,0,8,0"/>
                                <TextBlock Text="Chi tiêu" FontSize="14" Foreground="{DynamicResource MaterialDesignBody}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Top Categories -->
                <Border Background="White" CornerRadius="16" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Top danh mục chi tiêu" FontSize="18" FontWeight="Bold" 
                                 Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,24"/>

                        <ListView x:Name="TopCategoriesListView" Height="200" Width="Auto" HorizontalAlignment="Stretch">
                            <ListView.View>
                                <GridView >
                                    <GridViewColumn Header="Danh mục" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{Binding Color}" 
                                                           CornerRadius="10" Width="20" Height="20" 
                                                           Margin="0,0,8,0">
                                                        <materialDesign:PackIcon Kind="Shopping" Width="12" Height="12" 
                                                                               Foreground="White" HorizontalAlignment="Center" 
                                                                               VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding CategoryName}" 
                                                             VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Số tiền" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Amount, StringFormat=₫\{0:N0\}}" 
                                                         Foreground="#F44336" FontWeight="Bold"
                                                         VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Tỷ lệ" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Percentage, StringFormat=\{0:F1\}%}" 
                                                         VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Số giao dịch" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TransactionCount}" 
                                                         VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>