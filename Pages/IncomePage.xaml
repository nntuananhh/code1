<Page x:Class="WpfApp3.Pages.IncomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Thu nhập">

    <Grid Background="#FAFAFA">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
            <StackPanel>


                <!-- Action Buttons -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Add Income Button -->
                    <Button x:Name="AddIncomeButton" Grid.Column="0" Margin="0,0,8,0" 
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#4CAF50" Foreground="White"
                            Click="AddIncomeButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="20" Height="20" 
                                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Thêm thu nhập" FontSize="16" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <!-- Filter Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="ThisYearButton" Content="Năm nay" 
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Click="FilterButton_Click" Tag="ThisYear"/>
                    </StackPanel>
                </Grid>

                <!-- Search and Advanced Filters -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Box -->
                    <TextBox x:Name="SearchTextBox" Grid.Column="0" 
                            materialDesign:HintAssist.Hint="Tìm kiếm theo mô tả..."
                            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                            TextChanged="SearchTextBox_TextChanged"
                            Margin="0,0,8,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Advanced Filter Button -->
                    <Button x:Name="AdvancedFilterButton" Grid.Column="1" 
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{DynamicResource PrimaryHueMidBrush}" 
                            Foreground="Black"
                            Click="AdvancedFilterButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Filter" Width="20" Height="20" 
                                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Lọc nâng cao" FontSize="14" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Summary Cards -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Income -->
                    <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="24" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#4CAF50" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="TrendingUp" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Tổng thu nhập" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="TotalIncomeText" Text="₫0" FontSize="24" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- This Month Income -->
                    <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="24" Margin="6,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#2196F3" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="CalendarMonth" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Thu nhập tháng" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="MonthlyIncomeText" Text="₫0" FontSize="24" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Average Income -->
                    <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="24" Margin="12,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#FF9800" CornerRadius="12" Width="48" Height="48">
                                    <materialDesign:PackIcon Kind="ChartLine" Width="24" Height="24" 
                                                           Foreground="White" HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Thu nhập TB/tháng" FontSize="14" 
                                             Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                    <TextBlock x:Name="AverageIncomeText" Text="₫0" FontSize="24" FontWeight="Bold" 
                                             Foreground="{DynamicResource MaterialDesignBody}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Advanced Filter Panel -->
                <Border x:Name="AdvancedFilterPanel" Background="White" Padding="24" Margin="0,0,0,32" 
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Lọc nâng cao" FontSize="18" FontWeight="Bold" 
                                 Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Category Filter -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Danh mục" FontSize="14" FontWeight="Medium" Margin="0,0,0,8"/>
                                <ComboBox x:Name="CategoryFilterComboBox" 
                                        materialDesign:HintAssist.Hint="Chọn danh mục"
                                        DisplayMemberPath="Name"
                                        SelectedValuePath="Id"/>
                            </StackPanel>

                            <!-- Date Range -->
                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Text="Khoảng thời gian" FontSize="14" FontWeight="Medium" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DatePicker x:Name="FromDatePicker" Grid.Column="0" Margin="0,0,8,0"
                                              materialDesign:HintAssist.Hint="Từ ngày"/>
                                    <DatePicker x:Name="ToDatePicker" Grid.Column="1"
                                              materialDesign:HintAssist.Hint="Đến ngày"/>
                                </Grid>
                            </StackPanel>

                            <!-- Filter Actions -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Button x:Name="ApplyFilterButton" Content="Áp dụng" 
                                      Style="{StaticResource MaterialDesignRaisedButton}"
                                      Background="#4CAF50" Foreground="White"
                                      Click="ApplyAdvancedFilter_Click" Margin="0,0,8,0"/>
                                <Button x:Name="ClearFilterButton" Content="Xóa bộ lọc" 
                                      Style="{StaticResource MaterialDesignFlatButton}"
                                      Click="ClearAdvancedFilter_Click"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Income List -->
                <Border Background="White" CornerRadius="16" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Danh sách thu nhập" FontSize="20" FontWeight="Bold" 
                                 Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,24"/>

                        <!-- Income List -->
                        <ListView x:Name="IncomeListView" 
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  Height="Auto">
                            <ListView.View>
                                <GridView AllowsColumnReorder="False">
                                    <GridViewColumn Header="Ngày" Width="110">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Date, StringFormat='dd/MM/yyyy'}" 
                                                         VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Mô tả" Width="280">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Description}" 
                                                         VerticalAlignment="Center"
                                                         TextWrapping="Wrap"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Danh mục" Width="160">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="{Binding Category.Color}" 
                                                           CornerRadius="10" Width="20" Height="20" 
                                                           Margin="0,0,8,0">
                                                        <materialDesign:PackIcon Kind="CurrencyUsd" Width="12" Height="12" 
                                                                               Foreground="White" HorizontalAlignment="Center" 
                                                                               VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Category.Name}" 
                                                             VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Số tiền" Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Amount, StringFormat='₫{0:N0}'}" 
                                                         Foreground="#4CAF50" FontWeight="Bold"
                                                         VerticalAlignment="Center"
                                                         HorizontalAlignment="Right"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Thao tác" Width="Auto">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                            Click="EditButton_Click" Tag="{Binding Id}">
                                                        <materialDesign:PackIcon Kind="Edit" Width="16" Height="16"/>
                                                    </Button>
                                                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                                                            Foreground="#F44336"
                                                            Click="DeleteButton_Click" Tag="{Binding Id}">
                                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>